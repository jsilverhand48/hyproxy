{
  "listen": ":8443",
  "tls_cert": "../server/.dev/certs/idp.localhost.pem",
  "tls_key": "../server/.dev/certs/idp.localhost-key.pem",
  "authz_url": "http://127.0.0.1:8500",
  "auth_host": "auth.localhost",
  "auth_backend": "http://127.0.0.1:8500",
  "gateway_cookie_name": "__Secure-gw",
  "guac_backend": "http://127.0.0.1:8600",
  "routes_refresh_secs": 10,
  "lan_only_redirect": "https://idp.localhost:8443/auth/login",
  "log_dir": "",
  "log_level": "info",
  "log_max_bytes": 52428800,
  "log_backup_count": 2,
  "blocked_user_agents": [
    "(?i)(bot|crawler|spider|scrapy)",
    "(?i)(curl|wget|python-requests|go-http-client|libwww-perl)"
  ],
  "block_empty_user_agent": false,
  "blocked_ptr_suffixes": [
    "amazonaws.com",
    "googleusercontent.com",
    "cloudfront.net",
    "digitalocean.com",
    "linode.com",
    "ovh.net",
    "your-server.de"
  ],
  "block_any_resolvable_ptr": false,
  "blocked_asns": [],
  "blocked_countries": [],
  "geoip_asn_db": "",
  "geoip_country_db": "",
  "botfilter_cache_ttl_secs": 300,
  "routes": {
    "idp.localhost": {
      "backend": "http://127.0.0.1:8300",
      "auth": false
    },
    "admin.localhost": {
      "backend": "http://127.0.0.1:8400",
      "auth": false,
      "lan_only": true
    },
    "apps.localhost": {
      "backend": "http://127.0.0.1:8400",
      "auth": false,
      "guac_tunnel_path": true
    }
  }
}
