# hyproxy PRODUCTION environment. Copy to the repo-root `.env` and fill in.
#
#   cp .env.example .env   # then edit
#
# Consumed by: docker compose (variable substitution for the containerized
# control plane), bootstrap-prod.sh (first run), and start-prod.sh (every start).
# In the container model HYPROXY_DB_URL is derived from POSTGRES_PASSWORD (DB host
# is the `postgres` service), so you do NOT set it here.
#
# For LOCAL DEV use .env.dev.example (start-dev.sh seeds server/.env from it).
# For STAGING use .env.staging.example (prod vars + the LAN/ACME deploy vars).
#
# All application settings use the HYPROXY_ prefix; container env overrides any
# value baked into the image.

# ============================================================================
# REQUIRED
# ============================================================================

# Containerized Postgres password. Use a strong, unique value.
POSTGRES_PASSWORD=change-me-strong

# OIDC issuer = the public IdP origin. MUST be https in production. Also baked
# into the SPA at image build (VITE_IDP_ISSUER) and used to derive the WebAuthn
# RP ID (the issuer hostname). No trailing slash.
HYPROXY_ISSUER=https://idp.example.com

# Admin UI origin (scheme://host). The sole IdP CORS allowance and the only
# permitted step-up return target. The admin app also serves the SPA from here.
HYPROXY_ADMIN_UI_ORIGIN=https://admin.example.com

# Comma-separated client networks allowed to use the admin API, e.g. the
# server's own LAN subnet plus loopback. Defense in depth behind the data
# plane's lan_only edge block (the admin console is never internet-facing).
# Empty disables the check.
# HYPROXY_ADMIN_LAN_CIDRS=10.0.0.0/24,127.0.0.0/8

# Secrets backend: "file" (master key on disk) or "tpm" (sealed to the TPM,
# unsealed into memory only). Production target is tpm (docs/production.md).
HYPROXY_SECRETS_BACKEND=file
# file backend: HOST path to the master key file; compose mounts it as the
# `master_key` secret (read-only) into the control plane.
HYPROXY_MASTER_KEY_FILE=./server/.dev/master.keys
# tpm backend: persistent TPM handle of the sealed master key (unsealed at
# startup via tpm2_unseal) and the PCR selection it was sealed under (MUST
# match sealing time). install.sh seals the key and writes these, plus
# HYPROXY_TPM_DEVICE=/dev/tpmrm0 and TSS_GID=<gid of the host 'tss' group>
# so docker-compose.yml passes the TPM device into the control plane.
# HYPROXY_TPM_SEALED_BLOB=0x81010001
# HYPROXY_TPM_PCRS=sha256:0,2,4,7
# HYPROXY_TPM_DEVICE=/dev/tpmrm0
# TSS_GID=

# ============================================================================
# FIRST-RUN ADMIN (read by bootstrap-prod.sh; not application config)
# ============================================================================
ADMIN_EMAIL=admin@example.com
ADMIN_NAME="Site Admin"
# Defaults to <HYPROXY_ADMIN_UI_ORIGIN>/callback if unset.
# ADMIN_UI_REDIRECT=https://admin.example.com/callback

# ============================================================================
# OPTIONAL — SPA build
# ============================================================================
# OIDC client id the SPA authenticates as (must match the registered admin-ui
# client). Baked into the bundle at image build.
# VITE_ADMIN_UI_CLIENT_ID=admin-ui

# ============================================================================
# OPTIONAL — Guacamole browser bridges (enables the compose `guac` profile)
# ============================================================================
# Base64 of a 32-byte AES-256-CBC key (`make gen-guac-key` or
# `docker compose run --rm cli gen-guac-key`). Shared with the tunnel service.
# Empty disables guac.
# HYPROXY_GUAC_CYPHER_KEY=
# Seconds a minted tunnel token is valid (single-use regardless).
# HYPROXY_GUAC_GRANT_TTL=60

# ============================================================================
# OPTIONAL — gateway / backchannel (defaults shown; override for your topology)
# ============================================================================
# Public hostname for the gateway endpoints (data-plane auth_host).
# HYPROXY_AUTH_HOST=auth.example.com
# Scheme browsers use for gateway redirects.
# HYPROXY_EXTERNAL_SCHEME=https
# Gateway cookie domain: empty = host-only; set a parent domain to share.
# HYPROXY_GATEWAY_COOKIE_DOMAIN=
# Internal address for the authz->IdP token backchannel (defaults to the issuer).
# HYPROXY_IDP_INTERNAL_URL=
# Verify TLS on the backchannel. Keep true in production (no skip-verify).
# HYPROXY_IDP_VERIFY_TLS=true

# ============================================================================
# OPTIONAL — token/session TTLs and throttle (seconds; defaults shown)
# ============================================================================
# HYPROXY_ACCESS_TTL=600
# HYPROXY_REFRESH_ABS_TTL=21600
# HYPROXY_IDLE_TTL=1800
# HYPROXY_STEPUP_MAX_AGE=300
# HYPROXY_DPOP_IAT_WINDOW=300
# HYPROXY_THROTTLE_WINDOW=900
# HYPROXY_THROTTLE_ACCOUNT_FREE_FAILURES=3
# HYPROXY_THROTTLE_IP_FREE_FAILURES=10
