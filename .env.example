# Copy to .env and adjust. All settings use the hyproxy_ prefix.

# Docker Compose Postgres (make up):
HYPROXY_DB_URL=postgresql+asyncpg://hyproxy:devonly@127.0.0.1:5433/hyproxy
# pgserver fallback (make db-up prints the actual URL):
# HYPROXY_DB_URL=postgresql+asyncpg://postgres@/hyproxy?host=/path/to/socket

HYPROXY_MASTER_KEY_FILE=./.dev/master.keys
HYPROXY_ISSUER=https://idp.localhost:8300

# TTL knobs (seconds)
HYPROXY_ACCESS_TTL=600
HYPROXY_REFRESH_ABS_TTL=21600
HYPROXY_IDLE_TTL=1800
HYPROXY_STEPUP_MAX_AGE=300
HYPROXY_DPOP_IAT_WINDOW=300
