# hyproxy STAGING environment (LAN-only). Copy to the repo-root `.env`.
#
#   cp .env.staging.example .env   # then edit
#
# Superset of .env.example: every production variable PLUS the staging-only
# deploy vars (LAN domain, data-plane ingress, and ACME/cert paths) consumed by
# deploy/render-dataplane-config.sh and deploy/acme/obtain-cert.sh. See
# docs/staging.md. DNS-provider API SECRETS do not go here; put them in a
# root-owned /etc/hyproxy/acme.env.

# ============================================================================
# PRODUCTION VARS (same as .env.example)
# ============================================================================
POSTGRES_PASSWORD=change-me-strong

# Issuer/origin use hostnames under HYPROXY_DOMAIN; the wildcard LE cert covers
# *.HYPROXY_DOMAIN so idp/admin/auth all validate. https, no trailing slash.
HYPROXY_ISSUER=https://idp.example.com
HYPROXY_ADMIN_UI_ORIGIN=https://admin.example.com
# LAN networks allowed to use the admin API (server subnet + loopback); the
# data plane also blocks non-LAN clients at the edge (lan_only route).
HYPROXY_ADMIN_LAN_CIDRS=10.0.0.0/24,127.0.0.0/8

HYPROXY_SECRETS_BACKEND=file
HYPROXY_MASTER_KEY_FILE=./server/.dev/master.keys
# HYPROXY_TPM_SEALED_BLOB=/etc/hyproxy/master.tpm

# First-run admin (bootstrap-prod.sh)
ADMIN_EMAIL=admin@example.com
ADMIN_NAME="Staging Admin"
# ADMIN_UI_REDIRECT=https://admin.example.com/callback

# SPA client id (baked at build; must match the registered admin-ui client)
# VITE_ADMIN_UI_CLIENT_ID=admin-ui

# Guacamole (optional; enables the guac profile)
# HYPROXY_GUAC_CYPHER_KEY=
# HYPROXY_GUAC_GRANT_TTL=60

# Gateway / backchannel (optional; defaults shown)
# HYPROXY_AUTH_HOST=auth.example.com
# HYPROXY_EXTERNAL_SCHEME=https
# HYPROXY_IDP_INTERNAL_URL=
# HYPROXY_IDP_VERIFY_TLS=true

# ============================================================================
# STAGING-ONLY — LAN domain + data-plane ingress
# ============================================================================
# Base domain; the data-plane config generator derives idp./admin./auth.<domain>.
HYPROXY_DOMAIN=example.com

# Data-plane TLS ingress (deploy/render-dataplane-config.sh writes dataplane/config.json).
DP_TLS_CERT=/etc/hyproxy/certs/fullchain.pem
DP_TLS_KEY=/etc/hyproxy/certs/privkey.pem
DP_LISTEN=:443
# Group granted read on the private key when the data plane runs de-privileged.
DP_TLS_GROUP=hyproxy
# Loopback backends the data plane proxies to (defaults shown; usually unchanged).
# IDP_BACKEND=http://127.0.0.1:8300
# ADMIN_BACKEND=http://127.0.0.1:8400
# AUTHZ_BACKEND=http://127.0.0.1:8500
# Extra app routes as a comma-LEADING JSON fragment (host -> route object), e.g.
# APP_ROUTES_JSON=,"photos.example.com":{"backend":"http://127.0.0.1:9101"}

# ============================================================================
# STAGING-ONLY — ACME / Let's Encrypt (deploy/acme/obtain-cert.sh)
# Non-secret knobs may live here; provider API creds go in /etc/hyproxy/acme.env.
# ============================================================================
# ACME_EMAIL=you@example.com
# LEGO_DNS_PROVIDER=godaddy
# LEGO_PATH=/etc/hyproxy/lego
# Use the Let's Encrypt STAGING CA for a dry run first (untrusted cert):
# ACME_STAGING=1
#
# Provider credentials belong in /etc/hyproxy/acme.env (root-owned, 0600), NOT
# here. For GoDaddy:
#   GODADDY_API_KEY=...
#   GODADDY_API_SECRET=...

# ============================================================================
# Centralized logging (JSON lines under one directory)
# ============================================================================
# All services log here (idp/admin/authz/cli/audit/ui/dataplane/tunnel), one
# file each, 50 MB rotation with 2 archives kept. install.sh creates the dir.
HYPROXY_LOG_DIR=/var/log/hyproxy
# HYPROXY_LOG_LEVEL=INFO
# HYPROXY_LOG_MAX_BYTES=52428800
# DP_LOG_LEVEL=info
