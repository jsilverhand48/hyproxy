# hyproxy LOCAL DEV environment (baremetal, loopback, self-signed TLS).
# start-dev.sh copies this to server/.env on first run; the Python services read
# it directly. For production use .env.example; for staging use
# .env.staging.example.
# All application settings use the HYPROXY_ prefix.

# Docker Compose Postgres (make up); dev-only password.
POSTGRES_PASSWORD=devonly
HYPROXY_DB_URL=postgresql+asyncpg://hyproxy:devonly@127.0.0.1:5433/hyproxy
# pgserver fallback (make db-up prints the actual URL):
# HYPROXY_DB_URL=postgresql+asyncpg://postgres@/hyproxy?host=/path/to/socket

HYPROXY_MASTER_KEY_FILE=./.dev/master.keys
HYPROXY_ISSUER=https://idp.localhost:8300

# Secrets backend: "file" (dev) or "tpm" (production). See docs/production.md.
HYPROXY_SECRETS_BACKEND=file
# HYPROXY_TPM_SEALED_BLOB=

# Admin UI (Phase 3). Dev serves the SPA from the admin app on loopback, so the
# origin is the admin app itself. Empty disables the IdP CORS allowance and the
# step-up return target. start-dev.sh sets this automatically when it builds the UI.
# HYPROXY_ADMIN_UI_ORIGIN=http://127.0.0.1:8400
# HYPROXY_ADMIN_UI_DIST=

# Guacamole browser bridges (Phase 4). Base64 of a 32-byte AES-256-CBC key
# (`make gen-guac-key`), shared with the tunnel as GUAC_CYPHER_KEY. Empty disables guac.
# HYPROXY_GUAC_CYPHER_KEY=
HYPROXY_GUAC_GRANT_TTL=60

# TTL knobs (seconds)
HYPROXY_ACCESS_TTL=600
HYPROXY_REFRESH_ABS_TTL=21600
HYPROXY_IDLE_TTL=1800
HYPROXY_STEPUP_MAX_AGE=300
HYPROXY_DPOP_IAT_WINDOW=300
