# Staging environment (LAN-only) — copy to the repo-root .env and fill in.
#
#   cp deploy/staging.env.example .env   # then edit
#
# This drives docker compose (control plane), start-prod.sh, and the
# deploy/ scripts. DNS provider API secrets do NOT go here — put them in a
# root-owned /etc/hyproxy/acme.env (see deploy/acme/obtain-cert.sh).
# All settings use hostnames under STAGING_DOMAIN; the wildcard LE cert covers
# *.STAGING_DOMAIN so idp/admin/auth all validate.

# --- Domain (used by deploy/render-dataplane-config.sh) ----------------------
STAGING_DOMAIN=staging.example.com

# --- Postgres (compose) ------------------------------------------------------
POSTGRES_PASSWORD=change-me-strong

# --- Control plane (compose + server) ----------------------------------------
# Issuer is the IdP origin; also baked into the SPA at image build (VITE_IDP_ISSUER)
# and used to derive the WebAuthn RP ID (idp.STAGING_DOMAIN).
HYPROXY_ISSUER=https://idp.staging.example.com
HYPROXY_ADMIN_UI_ORIGIN=https://admin.staging.example.com

# Secrets backend: 'file' for staging (master key on disk, mounted as a compose
# secret). Migrate to 'tpm' before any internet exposure (docs/production.md).
HYPROXY_SECRETS_BACKEND=file
HYPROXY_MASTER_KEY_FILE=./server/.dev/master.keys

# --- Data-plane cert paths (LE output; see deploy/acme/obtain-cert.sh) --------
DP_TLS_CERT=/etc/hyproxy/certs/fullchain.pem
DP_TLS_KEY=/etc/hyproxy/certs/privkey.pem
DP_LISTEN=:443
# Group granted read on the private key when the data plane runs de-privileged.
DP_TLS_GROUP=hyproxy

# --- First-run admin (consumed by bootstrap-prod.sh; not app config) ---------
# ADMIN_EMAIL=admin@staging.example.com
# ADMIN_NAME=Staging Admin
# ADMIN_UI_REDIRECT=https://admin.staging.example.com/callback
